# Copie este arquivo no final para .env e preencha os valores reais.
# NUNCA comite o arquivo .env no repositório.

# ---------------------------------------------------------------------------
# SERVIDOR
# ---------------------------------------------------------------------------
# Porta em que a aplicação irá escutar.
PORT=3000

# ---------------------------------------------------------------------------
# BANCO DE DADOS (exemplo MySQL)
# ---------------------------------------------------------------------------
# Endereço do servidor de banco de dados
DB_HOST=localhost

# Porta do banco de dados (exemplo MySQL: 3306)
DB_PORT=3306

# Usuário com acesso ao banco
DB_USER=usuario_do_banco

# Senha do usuário 
DB_PASSWORD=senha_segura_aqui

# Nome do banco de dados que a aplicação irá utilizar
DB_NAME=meu_app_db

# ---------------------------------------------------------------------------
# Espaço vazio para adicionar os valores
PORT=
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# ---------------------------------------------------------------------------
# Para criar no MySQL
Connection Name= A sua escolha
Hostname = DB_HOST
Port = DB_PORT
Username = DB_USER
Password = DB_PASSWORD
Defaut Schema = DB_NAME